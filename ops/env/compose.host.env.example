# ---- Global ----
PROJECT_NAME=mafia_like

# ---- Image tags (CI/CD에서 바꾸기 쉬움) ----
CADDY_IMAGE=caddy:2
POSTGRES_IMAGE=postgres:16
REDIS_IMAGE=redis:7

# ---- DB connection info ----
POSTGRES_DB=mafia_like
POSTGRES_USER=mafia_like
POSTGRES_PASSWORD=mafia_like_pw

# ---- Ports exposed to host ----
HTTP_PORT=80
HTTPS_PORT=443
POSTGRES_PORT=5432
REDIS_PORT=6379
